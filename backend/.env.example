DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Required — PostgreSQL only (no SQLite). Matches docker compose defaults if you publish Postgres on 5432:
DATABASE_URL=postgresql://accessdoc:accessdoc@127.0.0.1:5432/accessdoc

# Production CSRF (HTTPS): full origins with scheme — match every browser URL you use to log in / POST forms.
# On Railway, ``RAILWAY_PUBLIC_DOMAIN`` is merged into ALLOWED_HOSTS and CSRF_TRUSTED_ORIGINS automatically.
# For a custom domain only, set both hosts and origins explicitly, e.g.:
# DJANGO_CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com
# Behind nginx/Traefik/LB that terminates TLS (so Gunicorn sees HTTP). On Railway this defaults on when
# RAILWAY_PUBLIC_DOMAIN is set; override with DJANGO_BEHIND_PROXY=false if needed.
# DJANGO_BEHIND_PROXY=true
# Rare: plain-HTTP production (not recommended) — disable Secure cookies:
# DJANGO_INSECURE_COOKIES=true

# Defaults follow your process cwd: from backend/ use repo = parent and utils = ./utils;
# from repo root use utils = ./backend/utils. Override when needed:
# ACCESSDOC_REPO_ROOT=/absolute/path/to/AccessDocDemo
# ACCESSDOC_UTILS_DIR=/absolute/path/to/AccessDocDemo/backend/utils
# Legacy alias: ACCESSDOC_SCRIPTS_DIR (same as ACCESSDOC_UTILS_DIR)

# Redis: Railway/Heroku often expose REDIS_URL — it is used when CELERY_BROKER_URL is unset.
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
# REDIS_URL=redis://...

# Single container (Docker image default / Railway): run Celery beside Gunicorn. Turn off if you use a dedicated worker only.
ACCESSDOC_EMBEDDED_CELERY_WORKER=1

# true = use Celery worker + Redis; false = background thread in the Django process (default when DEBUG=1)
# ACCESSDOC_USE_CELERY=false

# Mount path for published builds (must match ``accessdoc.urls`` and pipeline ``baseUrl``).
# Use a single path segment unless you know what you are doing (e.g. ``/viewer/`` or ``/docs/``).
DOCUSAURUS_BASE_URL=/viewer/

# Shared Docusaurus project (defaults: repo ``demo_docs/``)
# ACCESSDOC_DOCUSAURUS_ROOT=/absolute/path/to/demo_docs
# Built snapshots: ``backend/templates/doc_builds/<upload_uuid>/`` by default (uuid = row pk)
# ACCESSDOC_DOCUSAURUS_BUILDS_ROOT=/absolute/path/to/doc_builds

ACCESSDOC_MAX_UPLOAD_MB=25
